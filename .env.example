# ============================================================
# PostgreSQL (Docker)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=apitest
POSTGRES_PASSWORD=apitest1234
POSTGRES_DB=api_collect

# ============================================================
# 공공데이터포털 API 인증키
# 복지로(중앙/지자체) + 서민금융진흥원 공통 사용
# 발급: https://www.data.go.kr → 마이페이지 → 개발계정
# ============================================================
PUBLIC_API_KEY=example

# ============================================================
# 법제처 국가법령정보 Open API 키 (OC 파라미터)
# 법령 본문 + 판례 API 공통 사용
# 발급: https://open.law.go.kr → 오픈API → 이용신청
# ============================================================
LAW_OC_KEY=example

# ============================================================
# 수집 설정
# ============================================================
# discover 시 display 미지정 기본 페이지 크기 (운영 시 100~1000 권장)
COLLECT_PAGE_SIZE=10
# sync 상세 호출 간 딜레이 (초) - 공공 API 속도 제한 준수
REQUEST_DELAY_SECONDS=0.5
